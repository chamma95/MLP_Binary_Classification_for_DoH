# Allow only source files and documentation
# Deny everything by default
*
!.gitignore
!*.py
!*.txt
!*.md
!.github/
!.github/**

# Explicitly exclude folders
Data/
.venv/
venv/
.vscode/
.idea/
__pycache__/

# Python cache
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

